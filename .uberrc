#!/bin/zsh

#################
####   env   ####
#################

export DEVPOD_GO="rkochp-go.devpod-bra"
export DEVPOD_WEB="rkochp-web.devpod-bra"

if [ -d "$HOME/go-code" ]; then
    export GOMONOREPO="$HOME/go-code"
    export MONOREPO_BASE=$GOMONOREPO
    export WORKSPACE_ROOT=$GOMONOREPO
    export UPANEL="$GOMONOREPO/src/code.uber.internal/people/talent/upanel"
    export SCOUTHIRE="$GOMONOREPO/src/code.uber.internal/people/scout-hire"
    export CAREERS="$GOMONOREPO/src/code.uber.internal/people/careers"
fi
# override with sparse
if [ -d "$HOME/go-code-sparse" ]; then
    export GOMONOREPO="$HOME/go-code-sparse"
    export MONOREPO_BASE=$GOMONOREPO
    export WORKSPACE_ROOT=$GOMONOREPO
    export UPANEL="$GOMONOREPO/src/code.uber.internal/people/talent/upanel"
    export SCOUTHIRE="$GOMONOREPO/src/code.uber.internal/people/scout-hire"
    export CAREERS="$GOMONOREPO/src/code.uber.internal/people/careers"
fi


if [ -d "$HOME/web-code" ]; then
    export WEBMONOREPO="$HOME/web-code"
    export MONOREPO_BASE=$WEBMONOREPO
    export WORKSPACE_ROOT=$WEBMONOREPO
    export UPANELWEB="$WEBMONOREPO/src/platform/people/talent/upanel-web"
    export SCOUTFUSION="$WEBMONOREPO/src/platform/people/talent/scout-fusion"
    export CAREERSFUSION="$WEBMONOREPO/src/platform/people/talent/careers-fusion"
fi


#################
#### aliases ####
#################

alias cerb="cd $SCOUTHIRE && cerberus --no-status-page --quiet"

## upanel
alias cdup='cd $UPANEL'
alias upb='(cd $UPANEL && make build)'
alias upt='(cd $UPANEL && make test)'
alias uprr='(trap "kill 0" SIGINT; cd $UPANEL && direnv allow . && eval "$(direnv export bash)" && direnv status && cerberus >> /tmp/cerberus.log 2>&1 & make wonka >> /tmp/wonka.log 2>&1 & wait)'
alias upr='(trap "kill 0" SIGINT; cd $UPANEL && direnv allow . && eval "$(direnv export bash)" && direnv status && cerberus >> /tmp/cerberus.log 2>&1 & make wonka >> /tmp/wonka.log 2>&1 & make MONOREPO_BASE=$GOMONOREPO run)'
alias upd='(trap "kill 0" SIGINT; cd $UPANEL && direnv allow . && eval "$(direnv export bash)" && direnv status && cerberus >> /tmp/cerberus.log 2>&1 & make wonka >> /tmp/wonka.log 2>&1 & make MONOREPO_BASE=$GOMONOREPO debug)'
alias updbstag='dbt_cerb && dbt recon1 primary 17031'
alias updbprod='dbt_cerb && dbt recon primary 17030'
alias updbexp='dbt_cerb && dbt upanel_experimental primary 17032'
alias updbint='dbt_cerb && dbt upanel_integration_test primary 17033'
alias updbidev='dbt_cerb && dbt upanel_integration primary 17034'

## scout-hire
alias cdsh='cd $SCOUTHIRE'
alias cdshidl='cd ${GOMONOREPO}/idl/code.uber.internal/people/scout-hire'
alias shb='(cd $SCOUTHIRE && make build)'
alias sht='(cd $SCOUTHIRE && make test)'
alias shrr='(trap "kill 0" SIGINT; cd $SCOUTHIRE && direnv allow . && eval "$(direnv export bash)" && direnv status && cerberus >> /tmp/cerberus.log 2>&1 & wait)'
alias shr='(trap "kill 0" SIGINT; cd $SCOUTHIRE && direnv allow . && eval "$(direnv export bash)" && direnv status && cerberus >> /tmp/cerberus.log 2>&1 & make run)'
alias shdbint='dbt_cerb && dbt scout_hire_integration_test primary 17029'
alias shdbidev='dbt_cerb && dbt scout_hire_integration primary 17028'
alias shdbexp='dbt_cerb && dbt scout_hire_experimental primary 17027'
alias shdbstag='dbt_cerb && dbt scout_staging primary 17026'
alias shdbprod='dbt_cerb && dbt scout_hire_prod2'
alias shupexp='upbuild experimental scout-develop'
alias shupint='upbuild integration scout-integration-dev'
alias shupidev='upbuild integration-dev scout-integration-dev'

## arh
alias arb='arh rebase --sync'
alias arp='arh publish --no-interactive --auto-merge-all'

## web
alias cdsf='cd $SCOUTFUSION'
alias cdcf='cd $CAREERSFUSION'
alias jzf='jz focus'
alias jzd='jz dev'

## scout-fusion
alias sfupexp='upbuild experimental scout-develop scout-fusion'
alias sfupint='upbuild integration scout-integration scout-fusion'
alias sfupidev='upbuild integration-dev scout-integration scout-fusion'

## devpod
alias dp='devpod'
alias dpgo='ssh -Y $DEVPOD_GO'
alias dpweb='ssh -Y $DEVPOD_WEB'

## bazel
alias bz='bazel'
alias bzt='bz test'
alias bztv='bzt --test_output=all --test_summary=detailed --cache_test_results=false --test_arg=-test.v'
alias bztvr='bztv --test_env=GO_TEST_WRAP_TESTV=1 --@io_bazel_rules_go//go/config:race'
alias bztv50='bztv --runs_per_test=50 --test_timeout=7200'

################
#### config ####
################

git config --global user.name "rkochp"
git config --global user.email "rkochp@ext.uber.com"

# -------------------------------------
# nvim Uber ---------------------------
if [ -f ~/.envrc.local.go-code ] && [ -d ~/go-code ] && [ ! -f ~/go-code/.envrc.local ]; then
  cp ~/.envrc.local.go-code ~/go-code/.envrc.local
fi

# -------------------------------------
# database tunnel ---------------------
#!/bin/bash

dbt_cerb () {
    (
	# --- Check if cerberus is already running ---
        if pgrep -x "cerberus" > /dev/null; then
            echo "Cerberus is already running. Skipping startup."
            return 0 
        fi
	# ---

	READY_MSG="Open status page"
	TIMEOUT_SECONDS=300
	START_TIME=$(date +%s)
	LOG_FILE=$(mktemp)

	echo "Starting cerberus..."

	cerberus -s grail-deployment-storage --no-status-page > "$LOG_FILE" 2>&1 &
	CERB_PID=$!

	echo "Waiting for cerberus to be ready..."
	while true; do
	    # 1. Check if the success message exists
	    if grep -q "$READY_MSG" "$LOG_FILE"; then
		break
	    fi

	    # 2. Check if cerb process is still running
	    if ! kill -0 $CERB_PID 2>/dev/null; then
		echo "Error: cerb process exited unexpectedly."
		exit 1
	    fi

	    # 3. Check for timeout
	    CURRENT_TIME=$(date +%s)
	    ELAPSED=$(( CURRENT_TIME - START_TIME ))

	    if [ $ELAPSED -ge $TIMEOUT_SECONDS ]; then
		echo "Error: Timed out waiting for cerb after ${TIMEOUT_SECONDS}s."
		kill $CERB_PID 2>/dev/null
		exit 1
	    fi

	    sleep 2
	done
	echo "Cerberus is ready"
    )
}


# 2. Loop until the success message appears in the log
TUNNEL_FOR_CLUSTER=$HOME/tunnel_for_cluster.sh 
dbt () {
	(
		trap "kill 0" SIGINT
		echo "usage dbt <db> <role> <port>"
		DB="${1-scout_hire_prod2}"
		ROLE="${2-primary}"
		PORT="${3-17025}"
		storage credential -t soadbmysql -i ${DB} -d ${DB}
		echo "Connecting to DB: ${DB} as ROLE: ${ROLE} on PORT: ${PORT}"
		# cerberus -s grail-deployment-storage --no-status-page --quiet &
		# sleep 15
		$TUNNEL_FOR_CLUSTER $DB $ROLE $PORT
		echo "all done"
	)
}

# -------------------------------------
# direnv ------------------------------
if type "direnv" > /dev/null; then
  eval "$(direnv hook zsh)"
fi

# -------------------------------------
# arc/arh -----------------------------
if [ ! -z $(command -v arh) ] && [ ! -f "$HOME/.zsh/functions/_arh" ]; then 
	mkdir -p "$HOME/.zsh/functions" && \
		arh completion zsh > "$HOME/.zsh/functions/_arh"
fi

# -------------------------------------
# Up build ----------------------------
upbuild() 
{ 
	_ENV=${1:-experimental}
	_BRANCH=${2:-scout-develop}
	_SERVICE=${3:-scout-hire}
    echo "Starting build for $_SERVICE $_ENV...";
	exec 5>&1
    local output=$(ubuild build create $_SERVICE -b $_BRANCH -t prod -w | tee /dev/fd/5; exit ${PIPESTATUS[0]});
    local revision_id=$(echo "$output" | grep "Revision ID:" | awk '{print $3}');
    if [ -n "$revision_id" ]; then
        echo "";
        echo "========================================";
        echo "Build completed! Revision ID: $revision_id";
        echo "Triggering deployment...";
        echo "========================================";
        up compute deploy --service $_SERVICE --environment $_ENV --build-id "$revision_id" --policy non-production;
    else
        echo "ERROR: Could not extract Revision ID from build output";
        return 1;
    fi
}

# -------------------------------------
# fix gdate Uber ---------------------
[ -r "${HOME}"/.profile_lda ] && . "${HOME}"/.profile_lda

# -------------------------------------
# fix Bazel downloads -----------------
# On ~/.bazelrc:
#   common --repo_env=NETRC=/home/user/.netrc
export NETRC=~/.netrc
